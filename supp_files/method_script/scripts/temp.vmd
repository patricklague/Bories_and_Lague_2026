# source into TKconsole in VMD

package require psfgen

readpsf /media/bories/Backup/bories/Documents/Travail/results/homoPOPC-aa/homoPOPC-SCKN/charmm-gui/namd/step5_input.psf
coordpdb /media/bories/Backup/bories/Documents/Travail/results/homoPOPC-aa/homoPOPC-SCKN/charmm-gui/namd/step5_input.pdb

mol load psf /media/bories/Backup/bories/Documents/Travail/results/homoPOPC-aa/homoPOPC-SCKN/charmm-gui/namd/step5_input.psf pdb /media/bories/Backup/bories/Documents/Travail/results/homoPOPC-aa/homoPOPC-SCKN/charmm-gui/namd/step5_input.pdb

set all [atomselect top "all"]

#set sel1 [atomselect top "not (water or resname CLA or resname SOD or hydrogen)"]
set sel1 [atomselect top "not (water or resname CLA or resname SOD or resname POPC)"]
set sel2 [atomselect top "not [$sel1 text]"]

set indices [$sel1 get index]
set file [open findexfile.ind w]

foreach i $indices {
            puts $file $i
}

flush $file
close $file 

foreach segid [$sel2 get segid] resid [$sel2 get resid] atomname [$sel2 get name] {
   delatom $segid $resid $atomname
}

writepsf analog-SCKN.psf
writepdb analog-SCKN.pdb

exit
