# source /home/plague/Téléchargements/vmd_density_profile-1.3/density_profile.tcl
# multiply mass values by 1,660538921  (g/mol/A^3 = amu ; 1u = 1,660 538 921 × 10−27 kg; then conversion to g/cm^3)

#package require density_profile
source density_profile.tcl

mol load psf PSFFILE dcd ./trajectory.dcd

# nb frames -1
set nf [molinfo top get numframes]
set last [expr $nf - 1]

